---
import Site from "../layouts/Site.astro";
---

<Site title="Customize — Studio Ke">
	<section aria-labelledby="customize-heading">
		<h2 id="customize-heading" class="section-heading">Customize</h2>
		<div class="prose">
			<p>
				[A short intro about working with you on a custom piece — sizing, fabric choice, the design conversation, timeline, pricing range.]
			</p>
			<p>
				[Tell people how to get in touch to start a custom order. A simple form or an email link will live here.]
			</p>
		</div>
		<p class="coming-soon">Custom order form coming soon.</p>
	</section>
</Site>
