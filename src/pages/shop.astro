---
import Site from "../layouts/Site.astro";
---

<Site title="Shop — Studio Ke">
	<section aria-labelledby="shop-heading">
		<h2 id="shop-heading" class="section-heading">Shop</h2>
		<div class="prose">
			<p>
				[A short note about what you sell — one-of-a-kind handmade pieces, small batches, fabrics you've sourced and stitched yourself. Mention turnaround times, sizing, and anything a first-time buyer needs to feel comfortable.]
			</p>
		</div>
		<p class="coming-soon">The shop is being stitched together — pieces dropping soon.</p>
	</section>
</Site>
