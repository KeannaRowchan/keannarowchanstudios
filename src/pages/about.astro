---
import "../styles/global.css";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Keanna Rowchan</title>
	</head>
	<body class="bg-white text-gray-800 antialiased">
		<main class="max-w-3xl mx-auto px-6 pt-20 pb-24">
			<!-- Hero: name + role -->
			<section class="text-center mb-14">
				<h1 class="page-title text-5xl md:text-6xl font-bold text-gray-900 tracking-tight">
					Keanna Rowchan
				</h1>
				<p class="mt-4 text-base md:text-lg accent tracking-wide font-medium">
					PhD Student · Cognitive Neuroscience · Queen's University
				</p>
			</section>

			<!-- Blurb -->
			<section class="mb-12">
				<div class="max-w-2xl mx-auto text-center space-y-4 text-gray-700 leading-relaxed text-base md:text-lg">
					<p>
						I'm a PhD student in cognitive neuroscience at Queen's University, where I study whole-brain connectivity using dimensionality reduction and manifold learning approaches on fMRI data.
					</p>
					<p>
						Alongside my research, I sew. I'm building toward a career that combines technical work in computational analysis with the creative and material side of fashion.
					</p>
					<p>
						This site documents projects at that intersection.
					</p>
				</div>
			</section>

			<hr class="divider" />

			<!-- Research -->
			<section class="mb-20" aria-labelledby="heading-research">
				<h2 id="heading-research" class="section-heading">Research</h2>
				<div role="tablist" aria-labelledby="heading-research" class="tablist">
					<button role="tab" aria-selected="true" aria-controls="research-1" id="t-research-1" class="tab-btn">Research interests</button>
					<button role="tab" aria-selected="false" aria-controls="research-2" id="t-research-2" class="tab-btn">Education &amp; training</button>
					<button role="tab" aria-selected="false" aria-controls="research-3" id="t-research-3" class="tab-btn">Conferences &amp; presentations</button>
					<button role="tab" aria-selected="false" aria-controls="research-4" id="t-research-4" class="tab-btn">Publications</button>
				</div>

				<div id="research-1" role="tabpanel" aria-labelledby="t-research-1" class="tab-panel">
					<ul class="bullet-list">
						<li>Whole-brain functional connectivity</li>
						<li>Manifold learning &amp; dimensionality reduction</li>
						<li>fMRI analysis and computational methods</li>
						<li>[Add more interests here]</li>
					</ul>
				</div>

				<div id="research-2" role="tabpanel" aria-labelledby="t-research-2" class="tab-panel" hidden>
					<ul class="bullet-list">
						<li><strong>PhD, Cognitive Neuroscience</strong> — Queen's University · in progress</li>
						<li>[Prior degree(s) — institution, year]</li>
						<li>[Workshops, summer schools, certifications]</li>
					</ul>
				</div>

				<div id="research-3" role="tabpanel" aria-labelledby="t-research-3" class="tab-panel" hidden>
					<ul class="bullet-list">
						<li>[Talk title] — Conference name, Year</li>
						<li>[Poster title] — Conference name, Year</li>
					</ul>
				</div>

				<div id="research-4" role="tabpanel" aria-labelledby="t-research-4" class="tab-panel" hidden>
					<ol class="bullet-list list-decimal pl-6">
						<li>[Authors], &amp; <strong>Rowchan, K.</strong> ([Year]). [Title]. <em>[Journal]</em>, [volume]([issue]), [pages].</li>
						<li>[Add more publications here]</li>
					</ol>
				</div>
			</section>

			<hr class="divider" />

			<!-- Sewing -->
			<section aria-labelledby="heading-sewing">
				<h2 id="heading-sewing" class="section-heading">Sewing</h2>
				<div role="tablist" aria-labelledby="heading-sewing" class="tablist">
					<button role="tab" aria-selected="true" aria-controls="sewing-1" id="t-sewing-1" class="tab-btn">Exploring fashion in low dimensions</button>
					<button role="tab" aria-selected="false" aria-controls="sewing-2" id="t-sewing-2" class="tab-btn">Exploring multidimensions in pattern trends</button>
					<button role="tab" aria-selected="false" aria-controls="sewing-3" id="t-sewing-3" class="tab-btn">Personal sewing journey</button>
				</div>

				<div id="sewing-1" role="tabpanel" aria-labelledby="t-sewing-1" class="tab-panel">
					<p>
						[What does it mean to apply low-dimensional thinking to fashion? Describe the project — the question, the method, what you've made, what you've learned.]
					</p>
				</div>

				<div id="sewing-2" role="tabpanel" aria-labelledby="t-sewing-2" class="tab-panel" hidden>
					<p>
						[How are pattern trends structured across many dimensions? Describe the project — the data, the analysis, the resulting work.]
					</p>
				</div>

				<div id="sewing-3" role="tabpanel" aria-labelledby="t-sewing-3" class="tab-panel" hidden>
					<p>
						[Your personal sewing story — what drew you in, what you've made, where you're going.]
					</p>
				</div>
			</section>
		</main>

		<style>
			:root {
				--accent: #c64a73;
				--accent-soft: #ffe0eb;
				--accent-line: #ffb3c6;
			}

			body {
				font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
			}

			.page-title,
			.section-heading {
				font-family: "Georgia", "Times New Roman", serif;
			}

			.accent {
				color: var(--accent);
			}

			.section-heading {
				text-align: center;
				font-size: 1.875rem;
				font-weight: 600;
				color: #1f2937;
				margin-bottom: 1.5rem;
			}

			.divider {
				border: 0;
				border-top: 1.5px dashed var(--accent-line);
				margin: 3.5rem auto;
				max-width: 12rem;
			}

			.tablist {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 0.5rem;
				margin-bottom: 2rem;
			}

			.tab-btn {
				padding: 0.5rem 1.1rem;
				border: 1.5px solid var(--accent);
				border-radius: 9999px;
				color: var(--accent);
				font-size: 0.92rem;
				font-weight: 500;
				background: transparent;
				cursor: pointer;
				transition: background 0.15s ease, color 0.15s ease;
				line-height: 1.2;
				font-family: inherit;
			}
			.tab-btn:hover {
				background: var(--accent-soft);
			}
			.tab-btn[aria-selected="true"] {
				background: var(--accent);
				color: #ffffff;
			}
			.tab-btn:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: 2px;
			}

			.tab-panel {
				max-width: 38rem;
				margin: 0 auto;
				color: #374151;
				line-height: 1.65;
				font-size: 1rem;
			}

			.tab-panel[hidden] {
				display: none;
			}

			.bullet-list {
				list-style: disc;
				padding-left: 1.25rem;
			}
			.bullet-list > li + li {
				margin-top: 0.5rem;
			}
			.bullet-list.list-decimal {
				list-style: decimal;
			}
		</style>

		<script>
			document.querySelectorAll<HTMLElement>('[role="tablist"]').forEach((list) => {
				const tabs = Array.from(list.querySelectorAll<HTMLButtonElement>('[role="tab"]'));
				const section = list.closest("section")!;
				const panels = Array.from(section.querySelectorAll<HTMLElement>('[role="tabpanel"]'));

				function activate(target: HTMLButtonElement) {
					tabs.forEach((t) => {
						const selected = t === target;
						t.setAttribute("aria-selected", String(selected));
						t.tabIndex = selected ? 0 : -1;
					});
					panels.forEach((p) => {
						p.hidden = p.id !== target.getAttribute("aria-controls");
					});
				}

				tabs.forEach((tab, idx) => {
					tab.tabIndex = tab.getAttribute("aria-selected") === "true" ? 0 : -1;
					tab.addEventListener("click", () => activate(tab));
					tab.addEventListener("keydown", (e) => {
						let nextIdx: number | null = null;
						if (e.key === "ArrowRight") nextIdx = (idx + 1) % tabs.length;
						else if (e.key === "ArrowLeft") nextIdx = (idx - 1 + tabs.length) % tabs.length;
						else if (e.key === "Home") nextIdx = 0;
						else if (e.key === "End") nextIdx = tabs.length - 1;
						if (nextIdx !== null) {
							e.preventDefault();
							tabs[nextIdx].focus();
							activate(tabs[nextIdx]);
						}
					});
				});
			});
		</script>
	</body>
</html>
